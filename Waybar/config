{
    "layer": "top",
    "position": "top",
    "autohide": true,
    "autohide-delay": 0,
    "margin-top": 3,
    "height": 35,
    "spacing": 4,

    "modules-left": [
        "hyprland/workspaces",
        "cpu",
        "temperature",
        "memory"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "network",
        "battery",
        "pulseaudio",
        "tray"
    ],

    "hyprland/workspaces": {
    "class": "module",
    "on-click": "activate",
    "format": "{icon}",
    "format-icons": {
        "default": "○",
        "active": "●"
    }
    },
    "cpu": {
    "interval": 2,
    "format": " {usage}%",
    "tooltip": true,
    "states": { "warning": 70, "critical": 90 },
    "on-click": "foot -e btop++"
},
"temperature": {
    "interval": 5,
    "thermal-zone": 7,
    "hwmon-path": "/sys/class/hwmon/hwmon7/temp1_input",
    "critical-threshold": 80,
    "format": " {temperatureC}°C",
    "format-critical": " {temperatureC}°C",
    "tooltip": true,
    "states": { "warning": 55, "critical": 65 },
    "on-click": "foot -e btop++"
},
"memory": {
    "interval": 2,
    "format": "󰘚 {percentage}%",
    "tooltip": true,
    "states": { "warning": 70, "critical": 90 },
    "on-click": "foot -e btop++"
},
    "clock": {
        "class": "module",
        "interval": 1,
        "format": "{:%H:%M}",
        "format-alt": "{:%a, %d %b}",
        "tooltip-format": "<big>{:%Y %B %d}</big>\n<small>{:%A %H:%M}</small>",
        "on-click": "mode"
    },
    "network": {
    "class": "module",
    "interval": 5,
    "format-wifi": " {essid}",
    "format-ethernet": " {ipaddr}",
    "format-disconnected": "󰖪 Disconnected",
    "tooltip-format-wifi": "SSID: {essid}\nIP: {ipaddr}/{cidr}\nSignal: {signalStrength}%",
    "tooltip-format-ethernet": "IP: {ipaddr}/{cidr}",
    "tooltip-format-disconnected": "No network connection"
    },
    "battery": {
        "class": "module",
        "interval": 10,
        "format": "{icon} {capacity}%",
        "format-charging": "AC {capacity}%",
        "format-plugged": " {capacity}%",
        "format-alt": "{icon} {time}",
        "format-full": " Full",
        "format-icons": ["", "", "", "", ""],
        "states": { "warning": 30, "critical": 15 }
    },
    "pulseaudio": {
        "class": "module",
        "format": "墳 {volume}%",
        "format-muted": "Muted",
        "scroll-step": 5,
        "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +1%",
        "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -1%",
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-click-right": "pavucontrol"
    },
    "tray": {
        "class": "module",
        "icon-size": 18,
        "spacing": 8
    },
    "custom/power": {
        "class": "module",
        "format": "",
        "tooltip": "Power Menu",
        "on-click": "exec wlogout"
    }
}