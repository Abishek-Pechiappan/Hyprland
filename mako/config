# ~/.config/mako/config
# Catppuccin Macchiato "Liquid Glass" Theme

# General Options
font=JetBrainsMono Nerd Font 11
width=350
height=100
margin=10
padding=15
border-radius=10
border-size=2
icons=1
max-visible=5
default-timeout=5000

# Colors are in RRGGBBAA hex format for transparency
# This is @surface0 (313244) with ~60% alpha (99)
background-color=#31324499

# This is @text (cdd6f4)
text-color=#cdd6f4

# This is @lavender (b4befe) with ~30% alpha (4D)
border-color=#b4befe4D

# Style for different notification priorities
[urgency=low]
# This is @blue (89b4fa) with ~30% alpha (4D)
border-color=#89b4fa4D

[urgency=normal]
# Uses the default border color defined above
# border-color=#b4befe4D

[urgency=high]
# This is @red (f38ba8) with ~50% alpha (80)
border-color=#f38ba880
default-timeout=8000
